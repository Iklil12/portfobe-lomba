generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String          @id @default(uuid())
  email                  String          @unique
  password               String
  role                   Role            @default(USER)
  avatar                 String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  isLive                 Boolean         @default(false)
  emailVerified          DateTime?
  pendingEmail           String?
  accounts               Account[]
  activities             Activity[]
  analytics              Analytics[]
  certificates           Certificate[]
  dailyStats             DailyStats[]
  links                  Link[]
  profile                Profile?
  projects               Project[]
  siteAppearance         SiteAppearance?
  integrations           Integration[]
  canvaProjects          CanvaProject[]
  themeFavorites         ThemeFavorite[]
  testimonials           Testimonial[]
  visitorSessions        VisitorSession[]
  hourlyStats            HourlyStats[]
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "Account_userId_fkey")
}

model Profile {
  id               String  @id @default(uuid())
  userId           String  @unique
  fullName         String
  subdomain        String? @unique
  profession       String?
  bio              String? @db.Text
  avatarUrl        String? @db.Text
  coverUrl         String? @db.Text
  location         String?
  availableForHire Boolean @default(true)
  whatsapp         String?
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fullName])
}

model SiteAppearance {
  id            String  @id @default(uuid())
  userId        String  @unique
  splashScreen  Boolean @default(false)
  themeTemplate String  @default("minimalist")
  themeColor    String  @default("#000000")
  fontHeading   String  @default("Inter")
  fontBody      String  @default("Inter")
  buttonShape   String  @default("rounded")
  cardStyle     String  @default("flat")
  favoriteThemes String @default("[]") @db.Text
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ThemeFavorite {
  id        String   @id @default(uuid())
  userId    String
  themeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
  @@index([themeId])
  @@index([userId])
}

model Link {
  id       String  @id @default(uuid())
  userId   String
  platform String
  url      String  @db.Text
  isActive Boolean @default(true)
  order    Int     @default(0)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Link_userId_fkey")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  mediaUrl    String?
  projectType String   @default("photo")
  tags        String   @default("[]") @db.Text
  userId      String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?                    // null = aktif, ada nilai = di trash
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  detail3D    Project3DDetail?

  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId], map: "Project_userId_fkey")
}

model Project3DDetail {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileSize    Int
  storagePath String   // Nama/path file di Bunny.net untuk keperluan delete
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  details    String   @db.Text
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model Certificate {
  id          String   @id @default(uuid())
  title       String
  issuer      String?
  year        String?
  status      String?  @default("VERIFIED")
  description String?  @db.Text
  mediaUrl    String?
  userId      String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?                    // null = aktif, ada nilai = di trash
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Certificate_userId_fkey")
  @@index([deletedAt])
}

model Announcement {
  id         String   @id @default(uuid())
  title      String
  message    String   @db.Text
  type       String   @default("INFO")
  channel    String   @default("BOTH")
  targetPlan String   @default("ALL")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminEmail String
  action     String
  category   String   @default("GENERAL")
  target     String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([category])
  @@index([adminEmail])
}

model Analytics {
  id        String   @id @default(uuid())
  userId    String
  sessionId String?  // Optional for backward compatibility with old logs
  session   VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  type      String   @default("VIEW") // e.g., VIEW, CLICK, SCROLL, DOWNLOAD
  action    String?  // Spesifik aksi (e.g., "clicked_resume")
  targetId  String?  // ID dari elemen UI yang diinteraksikan
  metadata  Json?    // Data fleksibel, e.g., { scrollDepth: 80, timeSpent: 30 }
  
  ipAddress String?
  userAgent String?  @db.Text
  referrer  String?  @db.Text
  pagePath  String?
  duration  Int      @default(0) // Hanya relevan untuk VIEW
  
  // Geolocation & Device (Extracted)
  country   String?
  city      String?
  deviceType String? // Mobile, Desktop, Tablet
  os        String?
  browser   String?
  
  // Marketing UTM
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([type])
  @@index([sessionId])
  @@index([userId], map: "Analytics_userId_fkey")
}

model VisitorSession {
  id          String   @id @default(uuid())
  userId      String
  visitorId   String   // Cookie-based unique ID
  
  // Traffic Origin
  referrer    String?  @db.Text
  source      String?  // parsed: Instagram, Direct, Google, dll
  
  // Aggregated Session Data
  duration    Int      @default(0)
  isBounced   Boolean  @default(true) // Menjadi false jika duration > 10s atau pageview > 1
  
  // First touch Geolocation & Device
  country     String?
  city        String?
  deviceType  String?
  os          String?
  browser     String?
  ipAddress   String?

  // First touch UTM
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        Analytics[]

  @@index([userId])
  @@index([visitorId])
  @@index([createdAt])
}


model DailyStats {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  views     Int      @default(0)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model HourlyStats {
  id        String   @id @default(uuid())
  userId    String
  dateHour  DateTime // "2026-05-18T14:00:00Z"
  views     Int      @default(0)
  visitors  Int      @default(0) // Unique visitors di jam tersebut
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateHour])
  @@index([dateHour])
  @@index([userId])
}

model LoginAttempt {
  id        String    @id @default(uuid())
  ip        String
  email     String
  count     Int       @default(1)
  isBlocked Boolean   @default(false)
  blockedAt DateTime?
  updatedAt DateTime  @default(now()) @updatedAt

  @@index([email])
  @@index([ip])
}

model RegisterAttempt {
  id        String   @id @default(uuid())
  ip        String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ip])
}

enum Role {
  USER
  ADMIN
}

model Integration {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  providerId      String
  accessToken     String?  @db.Text              // Token akses API (misal: Penpot)
  settings        String?  @db.Text              // Pengaturan tambahan (misal: list file ID publik)
  cachedData      String?  @db.LongText  // JSON data yang dicache dari GitHub API
  cacheExpiresAt  DateTime?              // Kapan cache ini kedaluwarsa
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model CanvaProject {
  id          String   @id @default(uuid())
  userId      String
  title       String
  embedLink   String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Testimonial {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  clientName  String   // Nama pemberi testimoni (misal: "Budi Santoso")
  company     String?  // Posisi/Perusahaan (misal: "CEO di TechCorp" atau "Klien Freelance")
  content     String   @db.Text // Isi testimoni (maksimal misal 300-500 karakter)
  rating      Int      @default(5) // Rating 1-5 bintang
  avatarUrl   String?  // Foto pemberi testimoni (opsional)
  
  isVisible   Boolean  @default(true) // Toggle aktif/nonaktif tanpa harus hapus
  order       Int      @default(0) // Urutan tampilan
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

